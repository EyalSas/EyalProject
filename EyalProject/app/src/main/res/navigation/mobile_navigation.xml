<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.eyalproject.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_store"
        android:name="com.example.eyalproject.ui.store.StoreFragment"
        android:label="@string/title_store"
        tools:layout="@layout/fragment_store" />


    <fragment
        android:id="@+id/navigation_service"
        android:name="com.example.eyalproject.ui.service.ServiceFragment"
        android:label="@string/title_service"
        tools:layout="@layout/fragment_service">
        <argument
            android:name="USERNAME"
            app:argType="string" />
    </fragment>
</navigation>