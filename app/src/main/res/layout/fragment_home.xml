<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <LinearLayout
            android:id="@+id/heroBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="#0D2B4E"
            android:paddingTop="18dp"
            android:paddingBottom="44dp"
            android:paddingHorizontal="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoCard"
                android:layout_width="88dp"
                android:layout_height="88dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#DDE4EC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/icon"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/logoImage"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:visibility="gone" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Welcome to GameZone"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Your Ultimate Gaming Destination"
                android:textColor="#8AAAC8"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:weightSum="3"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A5F9E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_store"
                        app:tint="#FFFFFF"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/statsValue1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stores"
                        android:textSize="11sp"
                        android:textColor="#8AAAC8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard2"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#0D2B4E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_store"
                        app:tint="#8AAAC8"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/statsValue2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="170+"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Products"
                        android:textSize="11sp"
                        android:textColor="#8AAAC8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard3"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A5F9E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_store"
                        app:tint="#FFFFFF"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/statsValue3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24/7"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Support"
                        android:textSize="11sp"
                        android:textColor="#8AAAC8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK ACTIONS"
                    android:textColor="#0D2B4E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAbout"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="About Our Stores"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#0D2B4E"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_store"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="#8AAAC8" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F4F8"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFeatures"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Explore Features"
                    android:textColor="#0D2B4E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#0D2B4E"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_store"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="#1A5F9E" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F4F8"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonContact"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Contact Support"
                    android:textColor="#0D2B4E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#1A5F9E"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_store"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="#1A5F9E" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="invisible"
            app:indicatorColor="#1A5F9E"
            app:trackColor="#DDE4EC"
            app:trackCornerRadius="3dp"
            app:trackThickness="4dp" />

    </LinearLayout>
</ScrollView>