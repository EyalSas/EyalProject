<?xml version="1.0" encoding="utf-8"?>
<!-- Root layout for Service Management screen -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:padding="16dp"
    tools:context=".ui.service.ServiceFragment">

    <!-- Screen title -->
    <TextView
        android:id="@+id/title_service_management"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Service Management"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Overview cards showing stats (Waiting / Completed) -->
    <LinearLayout
        android:id="@+id/stats_overview_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/title_service_management"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Card showing "Waiting" services -->
        <include
            layout="@layout/stats_card_waiting"
            android:id="@+id/card_waiting"/>

        <!-- Card showing "Completed" services -->
        <include
            layout="@layout/stats_card_completed"
            android:id="@+id/card_completed"/>
    </LinearLayout>

    <!-- Input row for adding a new service request -->
    <LinearLayout
        android:id="@+id/add_service_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/stats_overview_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Text input for new service request -->
        <EditText
            android:id="@+id/edit_text_service_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter new service request..."
            android:textColorHint="#999999"
            android:textColor="#FFFFFF"
            android:background="@drawable/edittext_redesign"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:minHeight="48dp"/>

        <!-- Button to submit new service request -->
        <Button
            android:id="@+id/btn_add_service"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:backgroundTint="#00BCD4"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:minHeight="48dp"/>
    </LinearLayout>

    <!-- Title for the list of service requests -->
    <TextView
        android:id="@+id/services_list_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Service Requests"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/add_service_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable container for dynamically added service items -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/services_list_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/services_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>