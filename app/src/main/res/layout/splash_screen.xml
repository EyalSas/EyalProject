<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".SplashScreenActivity">

    <!-- Animated Background Elements with improved positioning -->
    <ImageView
        android:id="@+id/bgCircle1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/circle_bg"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.15" />

    <ImageView
        android:id="@+id/bgCircle2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/circle_bg"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:alpha="0.15" />

    <!-- Additional background element for better visual balance -->
    <ImageView
        android:id="@+id/bgCircle3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/circle_bg"
        android:layout_centerInParent="true"
        android:layout_marginStart="100dp"
        android:layout_marginTop="100dp"
        android:alpha="0.08" />

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="40dp">

        <!-- App Logo with shadow and better sizing -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logoCard"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@android:color/white">

            <ImageView
                android:id="@+id/logoImageView"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:src="@drawable/iconapp"
                android:scaleType="centerInside" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Welcome Text with better typography -->
        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Welcome to VoltEdge"
            android:textColor="@android:color/black"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <!-- Tagline Text -->
        <TextView
            android:id="@+id/taglineText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Powering Your Digital Experience"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:fontFamily="sans-serif"
            android:alpha="0.7"
            android:letterSpacing="0.01" />

        <!-- Loading Section with improved layout -->
        <LinearLayout
            android:id="@+id/loadingContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/loading_background">

            <!-- Loading Spinner -->
            <ImageView
                android:id="@+id/loadingSpinner"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_loading"
                android:layout_marginEnd="12dp" />

            <!-- Loading Text -->
            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@android:color/black"
                android:textSize="15sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

    <!-- Version Info -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="Version 1.0.0"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:alpha="0.6"
        android:fontFamily="sans-serif" />

    <!-- Progress Bar with better styling -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="280dp"
        android:layout_height="6dp"
        android:layout_above="@id/versionText"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:indeterminate="true"
        app:trackThickness="6dp"
        app:trackColor="#33000000"
        app:indicatorColor="#FF6B35" />

</RelativeLayout>